# Supabase project URL. Find this in your Supabase project dashboard
# under Project Settings -> API. Safe to expose; do not include trailing slash.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable key (new naming for what used to be the anon key).
# Safe to expose to the browser; respects Row Level Security on the database.
# Find this under Project Settings -> API -> "Publishable / anon" key.
# Format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
